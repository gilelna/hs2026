{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "layout": {
      "wideSize": "1280px",
      "contentSize": "768px"
    },
    "spacing": {
      "padding": false,
      "margin": false,
      "blockGap": true,
      "units": ["px", "em", "rem", "%"],
      "spacingSizes": [
        { "slug": "none", "size": "0rem", "name": "None" },
        { "slug": "xs", "size": "0.5rem", "name": "XS" },
        { "slug": "sm", "size": "1rem", "name": "SM" },
        { "slug": "md", "size": "1.5rem", "name": "MD" },
        { "slug": "lg", "size": "2.5rem", "name": "LG" },
        { "slug": "xl", "size": "4rem", "name": "XL" }
      ]
    },
    "color": {
      "custom": true,
      "customGradient": true,
      "customDuotone": true,
      "palette": [
        { "slug": "black", "color": "#000000", "name": "Black" },
        { "slug": "dark", "color": "#232323", "name": "Dark" },
        { "slug": "gold", "color": "#C1A868", "name": "Gold" },
        { "slug": "green-dark", "color": "#026360", "name": "Green Dark" },
        { "slug": "peach", "color": "#F7BAA4", "name": "Peach" },
        { "slug": "teal", "color": "#409690", "name": "Teal" },
        { "slug": "soft-blue", "color": "#CBE3E5", "name": "Soft Blue" },
        { "slug": "light-blue", "color": "#F3F7FA", "name": "Light Blue" },
        { "slug": "light-purple", "color": "#F7F2F9", "name": "Light Purple" },
        { "slug": "pink", "color": "#F9F2F3", "name": "Pink" },
        { "slug": "white", "color": "#ffffff", "name": "White" }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "Quincy, serif",
          "slug": "title",
          "name": "Title"
        },
        {
          "fontFamily": "Effra, sans-serif",
          "slug": "body",
          "name": "Body"
        }
      ],
      "fontSizes": [
        { "slug": "xs", "size": "clamp(0.64rem, 0.56rem + 0.5vw, 0.75rem)", "name": "XS" },
        { "slug": "sm", "size": "clamp(0.8rem, 0.72rem + 0.5vw, 0.9375rem)", "name": "SM" },
        { "slug": "base", "size": "clamp(1rem, 0.9rem + 0.6vw, 1.17rem)", "name": "Base" },
        { "slug": "lg", "size": "clamp(1.25rem, 1.1rem + 0.8vw, 1.46rem)", "name": "LG" },
        { "slug": "xl", "size": "clamp(1.56rem, 1.3rem + 1vw, 1.82rem)", "name": "XL" },
        { "slug": "2xl", "size": "clamp(1.95rem, 1.6rem + 1.2vw, 2.28rem)", "name": "2XL" },
        { "slug": "3xl", "size": "clamp(2.44rem, 1.9rem + 1.4vw, 2.85rem)", "name": "3XL" },
        { "slug": "4xl", "size": "clamp(3.05rem, 2.3rem + 1.6vw, 3.56rem)", "name": "4XL" }
      ],
      "customFontSize": true,
      "customLineHeight": true
    },
    "custom": {
      "hs": {
        "breakpoints": {
          "xs": "0px",
          "sm": "640px",
          "md": "768px",
          "lg": "1024px",
          "xl": "1280px",
          "2xl": "1536px"
        }
      }
    },
    "disableLayoutStyles": true
  },
  "customTemplates": [
    {
      "name": "index",
      "title": "Default",
      "postTypes": ["page", "post"]
    }
  ],
  "templateParts": [
    {
      "name": "header",
      "title": "Header",
      "area": "header"
    },
    {
      "name": "footer",
      "title": "Footer",
      "area": "footer"
    }
  ],
  "styles": {
    "blocks": {
      "core/group": {
        "spacing": {
          "padding": { "top": "0", "right": "0", "bottom": "0", "left": "0" },
          "margin": "0"
        }
      },
      "core/columns": {
        "spacing": {
          "padding": { "top": "0", "right": "0", "bottom": "0", "left": "0" },
          "margin": "0"
        }
      },
      "core/column": {
        "spacing": {
          "padding": { "top": "0", "right": "0", "bottom": "0", "left": "0" },
          "margin": "0"
        }
      },
      "core/image": {
        "spacing": {
          "padding": { "top": "0", "right": "0", "bottom": "0", "left": "0" },
          "margin": "0"
        }
      }
    }
  }
}