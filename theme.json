{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "layout": {
      "wideSize": "1280px",
      "contentSize": "768px"
    },
    "spacing": {
      "padding": false,
      "margin": false,
      "blockGap": true,
      "units": ["px", "em", "rem", "%"],
      "spacingSizes": [
        { "slug": "none", "size": "0rem", "name": "None" },
        { "slug": "xs", "size": "0.5rem", "name": "XS" },
        { "slug": "sm", "size": "1rem", "name": "SM" },
        { "slug": "md", "size": "1.5rem", "name": "MD" },
        { "slug": "lg", "size": "2.5rem", "name": "LG" },
        { "slug": "xl", "size": "4rem", "name": "XL" },
        { "slug": "sp-1", "size": "0.25rem",   "name": "SP1 4px" },
        { "slug": "sp-2", "size": "0.375rem",  "name": "SP2 6px" },
        { "slug": "sp-3", "size": "0.625rem",  "name": "SP3 10px" },
        { "slug": "sp-4", "size": "1rem",      "name": "SP4 16px" },
        { "slug": "sp-5", "size": "1.625rem",  "name": "SP5 26px" },
        { "slug": "sp-6", "size": "2.625rem",  "name": "SP6 42px" },
        { "slug": "sp-7", "size": "4.25rem",   "name": "SP7 68px" },
        { "slug": "sp-8", "size": "6.875rem",  "name": "SP8 110px" },
        { "slug": "sp-9", "size": "11.125rem", "name": "SP9 178px" },
        { "slug": "section", "size": "clamp(3.5rem, 2rem + 6.5vw, 8rem)", "name": "Section Pad" }
      ]
    },
    "color": {
      "custom": true,
      "customGradient": true,
      "customDuotone": true,
      "palette": [
        { "slug": "black", "color": "#000000", "name": "Black" },
        { "slug": "dark", "color": "#232323", "name": "Dark" },
        { "slug": "gold", "color": "#C1A868", "name": "Gold" },
        { "slug": "green-dark", "color": "#026360", "name": "Green Dark" },
        { "slug": "peach", "color": "#F7BAA4", "name": "Peach" },
        { "slug": "teal", "color": "#409690", "name": "Teal" },
        { "slug": "soft-blue", "color": "#CBE3E5", "name": "Soft Blue" },
        { "slug": "light-blue", "color": "#F3F7FA", "name": "Light Blue" },
        { "slug": "light-purple", "color": "#F7F2F9", "name": "Light Purple" },
        { "slug": "pink", "color": "#F9F2F3", "name": "Pink" },
        { "slug": "white",     "color": "#ffffff", "name": "White" },
        { "slug": "espresso",  "color": "#1A1410", "name": "Espresso" },
        { "slug": "gold-deep", "color": "#A8904F", "name": "Gold Deep" },
        { "slug": "cream",     "color": "#FAF5EC", "name": "Cream" },
        { "slug": "berry",     "color": "#8B3A52", "name": "Berry" },
        { "slug": "deep-teal", "color": "#1E5E5B", "name": "Deep Teal" }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "Quincy, serif",
          "slug": "title",
          "name": "Title"
        },
        {
          "fontFamily": "Effra, sans-serif",
          "slug": "body",
          "name": "Body"
        }
      ],
      "fontSizes": [
        { "slug": "xs", "size": "clamp(0.64rem, 0.56rem + 0.5vw, 0.75rem)", "name": "XS" },
        { "slug": "sm", "size": "clamp(0.8rem, 0.72rem + 0.5vw, 0.9375rem)", "name": "SM" },
        { "slug": "base", "size": "clamp(1rem, 0.9rem + 0.6vw, 1.17rem)", "name": "Base" },
        { "slug": "lg", "size": "clamp(1.25rem, 1.1rem + 0.8vw, 1.46rem)", "name": "LG" },
        { "slug": "xl", "size": "clamp(1.56rem, 1.3rem + 1vw, 1.82rem)", "name": "XL" },
        { "slug": "2xl", "size": "clamp(1.95rem, 1.6rem + 1.2vw, 2.28rem)", "name": "2XL" },
        { "slug": "3xl", "size": "clamp(2.44rem, 1.9rem + 1.4vw, 2.85rem)", "name": "3XL" },
        { "slug": "4xl",     "size": "clamp(3.05rem, 2.3rem + 1.6vw, 3.56rem)",        "name": "4XL" },
        { "slug": "display", "size": "clamp(3rem, 1.133rem + 7.671vw, 6.5rem)",        "name": "Display" },
        { "slug": "h1",      "size": "clamp(2.5rem, 1.367rem + 4.658vw, 4.5rem)",      "name": "H1" },
        { "slug": "h2",      "size": "clamp(2rem, 1.467rem + 2.192vw, 3rem)",          "name": "H2" },
        { "slug": "h3",      "size": "clamp(1.625rem, 1.358rem + 1.096vw, 2.125rem)",  "name": "H3" },
        { "slug": "h4",      "size": "clamp(1.25rem, 1.05rem + 0.822vw, 1.625rem)",    "name": "H4" },
        { "slug": "body-lg", "size": "clamp(1.125rem, 0.991rem + 0.548vw, 1.375rem)",  "name": "Body LG" },
        { "slug": "label",   "size": "clamp(0.75rem, 0.683rem + 0.274vw, 0.875rem)",   "name": "Label" },
        { "slug": "micro",   "size": "clamp(0.625rem, 0.558rem + 0.274vw, 0.75rem)",   "name": "Micro" }
      ],
      "customFontSize": true,
      "customLineHeight": true
    },
    "custom": {
      "hs": {
        "breakpoints": {
          "xs": "0px",
          "sm": "640px",
          "md": "768px",
          "lg": "1024px",
          "xl": "1280px",
          "2xl": "1536px"
        }
      }
    },
    "disableLayoutStyles": true
  },
  "customTemplates": [
    {
      "name": "index",
      "title": "Default",
      "postTypes": ["page", "post"]
    }
  ],
  "templateParts": [
    {
      "name": "header",
      "title": "Header",
      "area": "header"
    },
    {
      "name": "footer",
      "title": "Footer",
      "area": "footer"
    }
  ],
  "styles": {
    "blocks": {
      "core/group": {
        "spacing": {
          "padding": { "top": "0", "right": "0", "bottom": "0", "left": "0" },
          "margin": "0"
        }
      },
      "core/columns": {
        "spacing": {
          "padding": { "top": "0", "right": "0", "bottom": "0", "left": "0" },
          "margin": "0"
        }
      },
      "core/column": {
        "spacing": {
          "padding": { "top": "0", "right": "0", "bottom": "0", "left": "0" },
          "margin": "0"
        }
      },
      "core/image": {
        "spacing": {
          "padding": { "top": "0", "right": "0", "bottom": "0", "left": "0" },
          "margin": "0"
        }
      }
    }
  }
}